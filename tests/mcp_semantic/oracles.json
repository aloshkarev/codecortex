{
  "version": 1,
  "anchors": {
    "symbol": "tool_names",
    "flow_from": "tool_names",
    "flow_to": "build_symbol_resolver",
    "source_file": "crates/cortex-mcp/src/tools.rs",
    "rel_source": "crates/cortex-mcp/src/handler.rs",
    "bogus_symbol": "__codecortex_no_such_symbol__"
  },
