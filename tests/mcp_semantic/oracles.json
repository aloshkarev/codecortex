        {
          "type": "min_length",
          "path": "data/definitions",
          "min": 1
        },
        {
          "type": "contains",
          "path": "data/definitions/0/name",
          "substring": "tool_names"
        }
      ],
      "description_keywords": [
        "definition"
      ],
      "negative_control": {
        "args": {
          "symbol": "__codecortex_no_such_symbol__",
          "from_file": "crates/cortex-mcp/src/tools.rs",
          "repo_path": "${REPO}"
        },
        "assertions": [
          {
            "type": "max_length",
            "path": "data/definitions",
            "max": 0
