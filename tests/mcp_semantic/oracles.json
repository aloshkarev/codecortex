    {
      "tool": "check_health",
      "profile": [
        "pr",
        "nightly"
      ],
      "tier": "none",
      "description_claim": "Reports graph backend health",
      "args": {},
      "assertions": [
        {
          "type": "exists",
          "path": "status"
        },
        {
          "type": "exists",
          "path": "data/graph"
        }
      ],
      "description_keywords": [
        "health",
        "graph"
      ]
    },
    {
      "tool": "index_status",
      "profile": [
        "pr",
        "nightly"
      ],
      "tier": "none",
      "description_claim": "Reports graph freshness for repo",
      "args": {
        "repo_path": "${REPO}"
      },
      "assertions": [
        {
          "type": "not_error"
        },
        {
          "type": "contains",
          "path": "data/freshness/graph",
          "substring": "fresh"
        }
      ],
      "description_keywords": [
        "freshness",
        "index"
      ]
    },
